# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

# Which LLM provider to use by default: "groq" or "gemini"
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# Country profile: "india" or "us" — drives currency, PII fields, depreciation rules
COUNTRY=india

# Neon Postgres connection string (real persistence layer — see project decisions)
DATABASE_URL=postgresql://user:password@host/dbname

# JWT signing key — leave blank here; generated for real later via scripts/generate_secret_key.py
API_SECRET_KEY=